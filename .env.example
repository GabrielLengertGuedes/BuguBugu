# Modelo de variáveis de ambiente — BUGU BUGU FC
# Copie este arquivo para .env e preencha com seus valores reais.
# O arquivo .env NÃO deve ir para o repositório (está no .gitignore).

# ID do Google Analytics (quando ativado — exige atualização da Política de Privacidade)
ANALYTICS_ID=

# Token do Mercado Pago (para pagamento online — fase futura)
MERCADOPAGO_TOKEN=

# Número de WhatsApp para venda da camisa (quando definido pelo clube)
# Formato: código do país + DDD + número, sem espaços ou símbolos
# Exemplo: 5511999999999
WHATSAPP_NUMERO=
